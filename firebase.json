{
    "hosting": [
        {
            "target": "main",
            "source": ".",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "southamerica-east1",
                "memory": "512MiB"
            }
        },
        {
            "target": "eastside",
            "source": ".",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "southamerica-east1",
                "memory": "512MiB"
            }
        },
        {
            "target": "site-cliente",
            "source": ".",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "frameworksBackend": {
                "region": "southamerica-east1",
                "memory": "512MiB"
            }
        }
    ],
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log"
            ]
        }
    ],
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    }
}