{
  "entities": {
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer of the barber shop.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the customer."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the customer."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the customer."
        },
        "email": {
          "type": "string",
          "description": "Email address of the customer.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the customer."
        },
        "notes": {
          "type": "string",
          "description": "Any notes about the customer."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName"
      ]
    },
    "Service": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service",
      "type": "object",
      "description": "Represents a service offered by the barber shop.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the service."
        },
        "description": {
          "type": "string",
          "description": "Description of the service."
        },
        "price": {
          "type": "number",
          "description": "Price of the service."
        },
        "duration": {
          "type": "string",
          "description": "Duration of the service (e.g., '45 min')."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL for the service's image.",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "price",
        "duration"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment scheduled with a customer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to Customer. (Relationship: Customer 1:N Appointment)"
        },
        "serviceId": {
          "type": "string",
          "description": "Reference to Service. (Relationship: Service 1:N Appointment)"
        },
        "startTime": {
          "type": "string",
          "description": "Start time of the appointment.",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "description": "End time of the appointment.",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Any notes about the appointment."
        }
      },
      "required": [
        "id",
        "customerId",
        "serviceId",
        "startTime",
        "endTime"
      ]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice for services rendered.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the invoice."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to Customer. (Relationship: Customer 1:N Invoice)"
        },
        "appointmentId": {
          "type": "string",
          "description": "Reference to Appointment. (Relationship: Appointment 1:1 Invoice)"
        },
        "invoiceDate": {
          "type": "string",
          "description": "Date the invoice was issued.",
          "format": "date-time"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount of the invoice."
        },
        "paymentStatus": {
          "type": "string",
          "description": "Payment status of the invoice (e.g., paid, unpaid, partially paid)."
        }
      },
      "required": [
        "id",
        "customerId",
        "appointmentId",
        "invoiceDate",
        "totalAmount",
        "paymentStatus"
      ]
    },
    "Promotion": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Promotion",
      "type": "object",
      "description": "Represents a promotional offer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the promotion."
        },
        "name": {
          "type": "string",
          "description": "Name of the promotion."
        },
        "description": {
          "type": "string",
          "description": "Description of the promotion."
        },
        "discountPercentage": {
          "type": "number",
          "description": "Discount percentage offered by the promotion."
        },
        "startDate": {
          "type": "string",
          "description": "Start date of the promotion.",
          "format": "date-time"
        },
        "endDate": {
          "type": "string",
          "description": "End date of the promotion.",
          "format": "date-time"
        },
        "serviceIds": {
          "type": "array",
          "description": "References to Services. (Relationship: Promotion N:N Service)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "discountPercentage",
        "startDate",
        "endDate"
      ]
    },
    "ScheduleSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Schedule Settings",
      "type": "object",
      "description": "Represents the barbershop's opening hours and schedule configuration.",
      "properties": {
        "workingHours": {
          "type": "object",
          "description": "Defines the standard working hours for each day of the week.",
          "properties": {
            "sunday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "monday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "tuesday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "wednesday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "thursday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "friday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "saturday": {
              "$ref": "#/backend/entities/DaySetting"
            }
          }
        }
      }
    },
    "DaySetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Day Setting",
      "type": "object",
      "description": "Represents the settings for a single day of the week.",
      "properties": {
        "isOpen": {
          "type": "boolean",
          "description": "Whether the shop is open on this day."
        },
        "startTime": {
          "type": "string",
          "description": "The opening time, e.g., '09:00'."
        },
        "endTime": {
          "type": "string",
          "description": "The closing time, e.g., '18:00'."
        },
        "breaks": {
          "type": "array",
          "description": "A list of recurring break times for this day.",
          "items": {
            "$ref": "#/backend/entities/BreakTime"
          }
        }
      },
      "required": [
        "isOpen"
      ]
    },
    "BreakTime": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Break Time",
      "type": "object",
      "description": "Represents a recurring break time within a working day (e.g., lunch).",
      "properties": {
        "startTime": {
          "type": "string",
          "description": "The start time of the break, e.g., '12:00'."
        },
        "endTime": {
          "type": "string",
          "description": "The end time of the break, e.g., '13:00'."
        }
      },
      "required": [
        "startTime",
        "endTime"
      ]
    },
    "BlockedTime": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Blocked Time",
      "type": "object",
      "description": "Represents a time slot blocked by an admin, making it unavailable for appointments.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the blocked time slot."
        },
        "startTime": {
          "type": "string",
          "description": "Start time of the block.",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "description": "End time of the block.",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "description": "Reason for blocking the time slot (e.g., 'Lunch', 'Holiday')."
        }
      },
      "required": [
        "id",
        "startTime",
        "endTime",
        "reason"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": {
            "$ref": "#/backend/entities/Customer"
          },
          "description": "Stores customer information. The 'customerId' is used to identify the customer.",
          "params": [
            {
              "name": "customerId",
              "description": "The unique identifier for the customer."
            }
          ]
        }
      },
      {
        "path": "/customers/{customerId}/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores appointments scheduled for a customer.  Authorization Independence: Path-based ownership ensures that only the customer (or authorized personnel) can access these appointments.",
          "params": [
            {
              "name": "customerId",
              "description": "The unique identifier for the customer."
            },
            {
              "name": "appointmentId",
              "description": "The unique identifier for the appointment."
            }
          ]
        }
      },
      {
        "path": "/customers/{customerId}/invoices/{invoiceId}",
        "definition": {
          "entityName": "Invoice",
          "schema": {
            "$ref": "#/backend/entities/Invoice"
          },
          "description": "Stores invoices for a customer. Authorization Independence: Path-based ownership ensures that only the customer (or authorized personnel) can access these invoices.",
          "params": [
            {
              "name": "customerId",
              "description": "The unique identifier for the customer."
            },
            {
              "name": "invoiceId",
              "description": "The unique identifier for the invoice."
            }
          ]
        }
      },
      {
        "path": "/services/{serviceId}",
        "definition": {
          "entityName": "Service",
          "schema": {
            "$ref": "#/backend/entities/Service"
          },
          "description": "Stores services offered by the barber shop.",
          "params": [
            {
              "name": "serviceId",
              "description": "The unique identifier for the service."
            }
          ]
        }
      },
      {
        "path": "/promotions/{promotionId}",
        "definition": {
          "entityName": "Promotion",
          "schema": {
            "$ref": "#/backend/entities/Promotion"
          },
          "description": "Stores promotional offers.",
          "params": [
            {
              "name": "promotionId",
              "description": "The unique identifier for the promotion."
            }
          ]
        }
      },
      {
        "path": "/scheduleSettings/main",
        "definition": {
          "entityName": "ScheduleSettings",
          "schema": {
            "$ref": "#/backend/entities/ScheduleSettings"
          },
          "description": "Stores the main schedule settings for the barbershop as a singleton document.",
          "params": []
        }
      },
      {
        "path": "/blockedTimes/{blockedTimeId}",
        "definition": {
          "entityName": "BlockedTime",
          "schema": {
            "$ref": "#/backend/entities/BlockedTime"
          },
          "description": "Stores time slots that are manually blocked by administrators and are unavailable for appointments.",
          "params": [
            {
              "name": "blockedTimeId",
              "description": "The unique identifier for the blocked time entry."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to ensure data security, scalability, and ease of debugging. It uses path-based ownership for user-specific data like appointments and invoices, storing them under `/customers/{customerId}`. Global data like services, promotions, and schedule settings are stored in top-level collections with appropriate access controls. This segregation simplifies security rules and aligns with best practices by avoiding insecure `get()` calls in rules, ensuring that data access is determined by the query path itself. Schedule settings are stored in a singleton document (`/scheduleSettings/main`) for easy retrieval of global configuration."
  }
}
