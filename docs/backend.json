{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user of the application, who can be a customer, a professional, or an admin.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user, matches Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "Full name of the user."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the application.",
          "enum": ["client", "professional", "admin"]
        },
        "serviceIds": {
          "type": "array",
          "description": "For professionals, a list of service IDs they can perform.",
          "items": {
            "type": "string"
          }
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether the user account is disabled."
        }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Service": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service",
      "type": "object",
      "description": "Represents a service offered by the barber shop.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the service."
        },
        "description": {
          "type": "string",
          "description": "Description of the service."
        },
        "price": {
          "type": "number",
          "description": "Price of the service."
        },
        "duration": {
          "type": "string",
          "description": "Duration of the service (e.g., '45 min')."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL for the service's image.",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "price",
        "duration"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment scheduled with a customer for a specific professional.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to UserProfile (client). (Relationship: UserProfile 1:N Appointment)"
        },
        "professionalId": {
          "type": "string",
          "description": "Reference to UserProfile (professional). (Relationship: UserProfile 1:N Appointment)"
        },
        "serviceId": {
          "type": "string",
          "description": "Reference to Service. (Relationship: Service 1:N Appointment)"
        },
        "startTime": {
          "type": "string",
          "description": "Start time of the appointment.",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "description": "End time of the appointment.",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Any notes about the appointment."
        }
      },
      "required": [
        "id",
        "customerId",
        "professionalId",
        "serviceId",
        "startTime",
        "endTime"
      ]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice for services rendered.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the invoice."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to UserProfile (client). (Relationship: UserProfile 1:N Invoice)"
        },
        "appointmentId": {
          "type": "string",
          "description": "Reference to Appointment. (Relationship: Appointment 1:1 Invoice)"
        },
        "invoiceDate": {
          "type": "string",
          "description": "Date the invoice was issued.",
          "format": "date-time"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount of the invoice."
        },
        "paymentStatus": {
          "type": "string",
          "description": "Payment status of the invoice (e.g., paid, unpaid, partially paid)."
        }
      },
      "required": [
        "id",
        "customerId",
        "appointmentId",
        "invoiceDate",
        "totalAmount",
        "paymentStatus"
      ]
    },
    "Promotion": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Promotion",
      "type": "object",
      "description": "Represents a promotional offer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the promotion."
        },
        "name": {
          "type": "string",
          "description": "Name of the promotion."
        },
        "description": {
          "type": "string",
          "description": "Description of the promotion."
        },
        "discountPercentage": {
          "type": "number",
          "description": "Discount percentage offered by the promotion."
        },
        "startDate": {
          "type": "string",
          "description": "Start date of the promotion.",
          "format": "date-time"
        },
        "endDate": {
          "type": "string",
          "description": "End date of the promotion.",
          "format": "date-time"
        },
        "serviceIds": {
          "type": "array",
          "description": "References to Services. (Relationship: Promotion N:N Service)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "discountPercentage",
        "startDate",
        "endDate"
      ]
    },
    "ScheduleSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Schedule Settings",
      "type": "object",
      "description": "Represents the barbershop's opening hours and schedule configuration.",
      "properties": {
        "workingHours": {
          "type": "object",
          "description": "Defines the standard working hours for each day of the week.",
          "properties": {
            "sunday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "monday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "tuesday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "wednesday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "thursday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "friday": {
              "$ref": "#/backend/entities/DaySetting"
            },
            "saturday": {
              "$ref": "#/backend/entities/DaySetting"
            }
          }
        }
      }
    },
    "DaySetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Day Setting",
      "type": "object",
      "description": "Represents the settings for a single day of the week.",
      "properties": {
        "isOpen": {
          "type": "boolean",
          "description": "Whether the shop is open on this day."
        },
        "startTime": {
          "type": "string",
          "description": "The opening time, e.g., '09:00'."
        },
        "endTime": {
          "type": "string",
          "description": "The closing time, e.g., '18:00'."
        },
        "breaks": {
          "type": "array",
          "description": "A list of recurring break times for this day.",
          "items": {
            "$ref": "#/backend/entities/BreakTime"
          }
        }
      },
      "required": [
        "isOpen"
      ]
    },
    "BreakTime": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Break Time",
      "type": "object",
      "description": "Represents a recurring break time within a working day (e.g., lunch).",
      "properties": {
        "startTime": {
          "type": "string",
          "description": "The start time of the break, e.g., '12:00'."
        },
        "endTime": {
          "type": "string",
          "description": "The end time of the break, e.g., '13:00'."
        }
      },
      "required": [
        "startTime",
        "endTime"
      ]
    },
    "BlockedTime": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Blocked Time",
      "type": "object",
      "description": "Represents a time slot blocked by an admin, making it unavailable for appointments.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the blocked time slot."
        },
        "startTime": {
          "type": "string",
          "description": "Start time of the block.",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "description": "End time of the block.",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "description": "Reason for blocking the time slot (e.g., 'Lunch', 'Holiday')."
        }
      },
      "required": [
        "id",
        "startTime",
        "endTime",
        "reason"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile information, including their role (client, professional, admin).",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier for the user."
            }
          ]
        }
      },
       {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores all appointments. Access is controlled by security rules based on user role (client, professional, admin).",
          "params": [
            {
              "name": "appointmentId",
              "description": "The unique identifier for the appointment."
            }
          ]
        }
      },
      {
        "path": "/invoices/{invoiceId}",
        "definition": {
          "entityName": "Invoice",
          "schema": {
            "$ref": "#/backend/entities/Invoice"
          },
          "description": "Stores all invoices. Access is controlled by security rules.",
          "params": [
            {
              "name": "invoiceId",
              "description": "The unique identifier for the invoice."
            }
          ]
        }
      },
      {
        "path": "/services/{serviceId}",
        "definition": {
          "entityName": "Service",
          "schema": {
            "$ref": "#/backend/entities/Service"
          },
          "description": "Stores services offered by the barber shop.",
          "params": [
            {
              "name": "serviceId",
              "description": "The unique identifier for the service."
            }
          ]
        }
      },
      {
        "path": "/promotions/{promotionId}",
        "definition": {
          "entityName": "Promotion",
          "schema": {
            "$ref": "#/backend/entities/Promotion"
          },
          "description": "Stores promotional offers.",
          "params": [
            {
              "name": "promotionId",
              "description": "The unique identifier for the promotion."
            }
          ]
        }
      },
      {
        "path": "/scheduleSettings/main",
        "definition": {
          "entityName": "ScheduleSettings",
          "schema": {
            "$ref": "#/backend/entities/ScheduleSettings"
          },
          "description": "Stores the main schedule settings for the barbershop as a singleton document.",
          "params": []
        }
      },
      {
        "path": "/blockedTimes/{blockedTimeId}",
        "definition": {
          "entityName": "BlockedTime",
          "schema": {
            "$ref": "#/backend/entities/BlockedTime"
          },
          "description": "Stores time slots that are manually blocked by administrators and are unavailable for appointments.",
          "params": [
            {
              "name": "blockedTimeId",
              "description": "The unique identifier for the blocked time entry."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure has been updated to be more role-oriented. The 'customers' collection is now 'users', reflecting that a user can be a client, professional, or admin. Appointments and invoices have been moved to top-level collections to decouple them from a single user's data tree, preparing the system for more complex relationships, such as a professional's view of their own schedule. This flat structure simplifies queries and security rules, especially for features involving multiple user roles."
  }
}

    