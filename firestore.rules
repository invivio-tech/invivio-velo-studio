/**
 * Core Philosophy: This ruleset implements a flexible, role-based security model.
 * It distinguishes between 'admin', 'professional', and 'client' roles to grant
 * appropriate data access levels.
 *
 * Data Structure: User profiles are stored in the top-level `/users` collection.
 * Global data like services, appointments, and invoices are also in top-level
 * collections to allow for flexible and secure querying by different roles.
 * This avoids deep nesting and complex path-based security.
 *
 * Key Security Decisions:
 * - Admin Supremacy: Users with the 'admin' role have broad read and write access
 *   across most of the database for management purposes. This is checked using the `isAdmin()` function.
 * - Professional Access: Professionals can read their own profile and the appointments
 *   assigned to them. They can also manage their own schedule settings and blocked times.
 * - Client (Owner) Access: Standard users (clients) can only access their own
 *   user profile and appointments/invoices where their UID is listed. This is
 *   enforced using the `isOwner()` function.
 * - Secured Queries: Listing documents (e.g., all users, all appointments) is
 *   generally restricted to admins. Clients and professionals must query for data
 *   relevant to them (e.g., `where('customerId', '==', uid)`), which is then
 *   validated by the security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the core function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the currently authenticated user has the 'admin' role.
     * This function now checks for a specific email to avoid recursive lookups.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }


    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profiles (clients, professionals, admins).
     * @path /users/{userId}
     */
    match /users/{userId} {
      // A user can read their own profile. An admin can read any profile.
      // Any signed-in user can read the profile of a 'professional' to see their details for booking.
      allow get: if isOwner(userId) || isAdmin() || (resource.data.role == 'professional');
      // Allow signed-in users to perform queries (e.g., to find professionals).
      // The `get` rule above secures the individual documents returned by the query.
      allow list: if isSignedIn();
      // An unauthenticated user can create their own 'client' profile upon signing up.
      // An admin can create any user.
      allow create: if (isOwner(userId) && request.resource.data.role == 'client') || isAdmin();
      // A user can update their own profile, but cannot change their role.
      // An admin can update any profile.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Manages a professional's specific working hours.
       * @path /users/{userId}/scheduleSettings/main
       * @allow (read) Any signed-in user can see a professional's schedule.
       * @allow (write) Only the professional themself or an admin can change the schedule.
       */
      match /scheduleSettings/main {
        allow get, list: if isSignedIn();
        allow write: if isAdmin() || isOwner(userId);
      }

      /**
       * @description Manages a professional's specific blocked time slots.
       * @path /users/{userId}/blockedTimes/{blockedTimeId}
       * @allow (read) Any signed-in user can see a professional's blocks.
       * @allow (write) Only the professional themself or an admin can manage blocks.
       */
      match /blockedTimes/{blockedTimeId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin() || isOwner(userId);
      }
    }

    /**
     * @description Manages all appointments in the system.
     * @path /appointments/{appointmentId}
     */
    match /appointments/{appointmentId} {
      // READ: Split into GET and LIST for security and functionality.
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      // CREATE: A client can create their own appointment, or an admin can create any.
      allow create: if isOwner(request.resource.data.customerId) || isAdmin();

      // UPDATE, DELETE: Only the client who created the appointment or an admin can modify/cancel it.
      allow update, delete: if isOwner(resource.data.customerId) || isAdmin();
    }

    /**
     * @description Manages all invoices in the system.
     * @path /invoices/{invoiceId}
     * @allow (get) A client can get their own invoice. An admin can get any.
     * @allow (list) Signed-in users can list invoices (queries must be used to filter).
     * @allow (create, update, delete) Admin-only for creating/managing invoices.
     */
    match /invoices/{invoiceId} {
      allow get: if isAdmin() || isOwner(resource.data.customerId);
      allow list: if isSignedIn(); // Requires secure queries in the app
      allow create: if isOwner(request.resource.data.customerId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Publicly lists the categories for services.
     * @path /serviceCategories/{serviceCategoryId}
     * @allow (get, list) Any user, signed in or not, can read the list of categories.
     * @allow (write) Only authenticated admins can create, update, or delete categories.
     */
    match /serviceCategories/{serviceCategoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Publicly lists the services offered by the business.
     * @path /services/{serviceId}
     * @allow (get, list) Any user, signed in or not, can read the list of services.
     * @allow (write) Only authenticated admins can create, update, or delete services.
     * @principle Provides public read access for global data while securing modifications to admins only.
     */
    match /services/{serviceId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Publicly lists the promotions offered by the business.
     * @path /promotions/{promotionId}
     * @allow (get, list) Any user, signed in or not, can view promotional offers.
     * @allow (write) Only admins can manage promotions.
     */
    match /promotions/{promotionId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Manages the barbershop's general operating schedule.
     * @path /scheduleSettings/{docId}
     * @allow (get, list) Any user can read the schedule settings to check for availability.
     * @allow (write) Only authenticated admins can create, update, or delete schedule settings.
     * @principle Provides public read access for global configuration while securing modifications to admins only.
     */
    match /scheduleSettings/{docId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Manages globally blocked time slots on the schedule (e.g., holidays).
     * @path /blockedTimes/{blockedTimeId}
     * @allow (get, list) Any user can read blocked times to see availability.
     * @allow (write) Only authenticated admins can create, update, or delete blocked time slots.
     * @principle Provides public read access for global configuration while securing modifications to admins only.
     */
    match /blockedTimes/{blockedTimeId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Manages the establishment's public information (name, about text, etc.).
     * @path /establishmentSettings/{docId}
     * @allow (get, list) Any user can read the establishment settings for the landing page.
     * @allow (write) Only authenticated admins can create, update, or delete settings.
     */
    match /establishmentSettings/{docId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }
  }
}
