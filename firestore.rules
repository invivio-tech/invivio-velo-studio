rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();
      
      match /scheduleSettings/main {
        allow read, write: if isSignedIn();
      }
      match /blockedTimes/{blockedTimeId} {
        allow read, write: if isSignedIn();
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() || resource.data.isPortfolioFeatured == true;
      allow write: if isSignedIn();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /recurringExpenses/{recurringExpenseId} {
      allow read, write: if isSignedIn();
    }

    match /professionalTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /loyaltyTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /serviceCategories/{serviceCategoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Memberships (Clube de Assinatura) ─────────────────
    match /membershipPlans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /userMemberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // ── Store Collections ──────────────────────────────────
    // Product categories: anyone can read (for the public storefront),
    // only authenticated users (admins) can write.
    match /productCategories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Products: anyone can read active products in the public store,
    // only authenticated users (admins) can create/update/delete.
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Orders: anyone can create (guest checkout — name + phone only),
    // only signed-in users (admin) can read/update status.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Membership Invoices
    match /membershipInvoices/{document=**} {
      // Temporarily allow anyone signed in to manage invoices during MVP
      allow read, write: if isSignedIn();
    }
    
    match /scheduleSettings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /blockedTimes/{blockedTimeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /establishmentSettings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Marketing & Push Notifications Collections ──────────
    match /campaigns/{campaignId} {
      allow read, write: if isSignedIn();
    }

    match /pushLogs/{pushLogId} {
      allow read, write: if isSignedIn();
    }
  }
}
